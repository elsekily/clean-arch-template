{
  "$schema": "http://json.schemastore.org/template",
  "author": "Youssef Elsekily",
  "classifications": [
    "Clean Architecture",
    "API",
    "CQRS",
    "Web API"
  ],
  "identity": "Elsekily.CleanArchTemplate",
  "name": "Elsekily Clean Architecture Template",
  "shortName": "elsekily-api",
  "sourceName": "Elsekily",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "forms": {
    "pascalCase": {
      "identifier": "pascalCase"
    }
  },
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net8.0",
          "description": ".NET 8"
        },
        {
          "choice": "net10.0",
          "description": ".NET 10"
        }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    },
    "ProjectSafeName": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "pascalCase"
    },
    "DbContextName": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "AppDbContext",
      "fileRename": "AppDbContext",
      "parameters": {
        "source": "ProjectSafeName",
        "steps": [
          {
            "regex": "$",
            "replacement": "DbContext"
          }
        ]
      }
    },
    "UnitOfWorkName": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "AppUnitOfWork",
      "fileRename": "AppUnitOfWork",
      "parameters": {
        "source": "ProjectSafeName",
        "steps": [
          {
            "regex": "$",
            "replacement": "UnitOfWork"
          }
        ]
      }
    },
    "IUnitOfWorkName": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "IAppUnitOfWork",
      "fileRename": "IAppUnitOfWork",
      "parameters": {
        "source": "ProjectSafeName",
        "steps": [
          {
            "regex": "$",
            "replacement": "UnitOfWork"
          },
          {
            "regex": "^",
            "replacement": "I"
          }
        ]
      }
    },
    "ConnectionStringKey": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "\"App\":",
      "parameters": {
        "source": "ProjectSafeName",
        "steps": [
          {
            "regex": "^",
            "replacement": "\""
          },
          {
            "regex": "$",
            "replacement": "\":"
          }
        ]
      }
    },
    "ConnectionStringCall": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "GetConnectionString(\"App\")",
      "parameters": {
        "source": "ProjectSafeName",
        "steps": [
          {
            "regex": "^",
            "replacement": "GetConnectionString(\""
          },
          {
            "regex": "$",
            "replacement": "\")"
          }
        ]
      }
    },
    "HttpPort": {
      "type": "generated",
      "generator": "random",
      "parameters": {
        "low": 5000,
        "high": 9000
      },
      "replaces": "5000"
    },
    "HttpsPort": {
      "type": "generated",
      "generator": "random",
      "parameters": {
        "low": 5001,
        "high": 9001
      },
      "replaces": "5001"
    },
    "AppDirRename": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "AppDir",
      "fileRename": "AppDir",
      "parameters": {
        "source": "ProjectSafeName",
        "steps": []
      }
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "README.md",
            ".git/**",
            ".vs/**",
            "*.nuspec",
            "elsekily-template-install.json"
          ]
        }
      ]
    },
    {
      "source": ".template.config/resources",
      "target": "./",
      "include": [
        "README.md"
      ]
    }
  ],
  "description": "A Clean Architecture ASP.NET Core 10 solution template with CQRS (manual, no MediatR), Entity Framework Core, FluentValidation, Serilog, JWT auth, rate limiting, and Quartz.NET. By Youssef Elsekily.",
  "primaryOutputs": [
    {
      "path": "Elsekily.sln"
    }
  ]
}
